{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oseupsico",
  "main": "_worker.js",
  "compatibility_date": "2026-06-22",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "dev": {
    "port": 8787
  }
}
